# Copy this to .env and fill in your values
# cp .env.example .env

# OpenWeatherMap API Key
OWM_KEY=your_openweathermap_api_key_here

# Spotify App Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# Gemini API Key
GEMINI_KEY=your_gemini_api_key_here

# GitHub (optional, increases rate limit)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=oktavsm

# Secret for the /api/refresh endpoint (generate any random string)
REFRESH_SECRET=generate_a_random_secret_here
